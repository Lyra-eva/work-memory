# QQ 邮箱配置模板
# 复制此文件为 .env 并填入实际值

# QQ 邮箱地址（如：123456789@qq.com）
QQ_EMAIL_ADDRESS=your_qq_number@qq.com

# QQ 邮箱授权码（在 QQ 邮箱设置中获取）
QQ_EMAIL_AUTH_CODE=your_auth_code_here

# SMTP 配置（默认即可）
QQ_SMTP_SERVER=smtp.qq.com
QQ_SMTP_PORT=465

# IMAP 配置（默认即可）
QQ_IMAP_SERVER=imap.qq.com
QQ_IMAP_PORT=993

# 使用 SSL（推荐）
QQ_USE_SSL=true
