{
  "agent": {
    "default_agent_id": "lily",
    "enable_evolution": true,
    "auto_cleanup": true
  },
  "ooda": {
    "emotional_analysis": {
      "enabled": true,
      "sensitivity": 0.8,
      "positive_keywords": [
        "成功",
        "棒",
        "好",
        "太棒了",
        "excellent",
        "great"
      ],
      "negative_keywords": [
        "失败",
        "错",
        "失望",
        "糟糕",
        "fail",
        "error"
      ]
    },
    "intent_classification": {
      "enabled": true,
      "auto_detect": true
    },
    "decision": {
      "bandit_algorithm": "ucb1",
      "exploration_weight": 0.3,
      "risk_thresholds": {
        "low": 0.7,
        "medium": 0.4,
        "high": 0.0
      }
    }
  },
  "graph": {
    "storage_backend": "sqlite",
    "db_path": "/home/admin/.openclaw/workspace/memory/cognition/graph.db",
    "auto_create_relations": true,
    "relation_thresholds": {
      "similarity_min": 0.6,
      "dependency_auto_detect": false
    }
  },
  "logging": {
    "level": "INFO",
    "enable_detailed_output": true,
    "log_to_file": false,
    "log_path": "/home/admin/.openclaw/workspace/logs/evolution.log"
  },
  "performance": {
    "cache_enabled": true,
    "cache_ttl_seconds": 600,
    "batch_processing": false,
    "async_execution": false
  }
}